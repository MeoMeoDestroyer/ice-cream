<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Confirm Order</title>
</head>
<body>
    <h1> Thank You For Your Order!</h1>
    <h2> Your ice cream order has been confirmed</h2>
    <h3> Personal Information</h3>
    <p>Name: <%= name %></p>
    <p>Email: <%= email %></p>
    <h3> Order Details</h3>
    <p>Flavor: <%= flavor %></p>
    <p>Cone: <%= cone %></p>
    <p>Toppings: <%= toppings %></p>

    <h3>Additional Comments</h3>
    <p><%= comments %></p>

    <a href="/print">Print Order</a>
    <a href ="/">Place Another Order</a>
    
</body>
</html>